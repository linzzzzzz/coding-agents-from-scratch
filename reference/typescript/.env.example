LLM_API_KEY=your-api-key
LLM_MODEL=qwen3.5-flash-2026-02-23
LLM_BASE_URL=https://api.openai.com/v1

# Optional: enables web search.
EXA_API_KEY=

# Optional: enables Laminar traces/evals.
LMNR_API_KEY=

# Optional: how often the app extracts semantic memory.
MEMORY_EXTRACT_EVERY_N_TURNS=3

# Optional: set to true to run shell commands through the sandbox command wrapper.
SANDBOX_COMMANDS=false
