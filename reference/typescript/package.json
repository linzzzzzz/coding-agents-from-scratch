{
  "name": "coding-agents-from-scratch-typescript-reference",
  "version": "1.0.0",
  "description": "Finished TypeScript reference implementation for Building Production AI Coding Agents from Scratch.",
  "main": "index.js",
  "type": "module",
  "bin": {
    "agi": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx --env-file=.env src/index.ts",
    "start": "tsx --env-file=.env src/index.ts",
    "test": "vitest run",
    "eval": "npx lmnr eval",
    "eval:file-tools": "npx lmnr eval evals/file-tools.eval.ts",
    "eval:shell-tools": "npx lmnr eval evals/shell-tools.eval.ts",
    "eval:agent": "npx lmnr eval evals/agent-multiturn.eval.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ai-sdk/openai": "^3.0.58",
    "@lmnr-ai/lmnr": "^0.8.22",
    "ai": "^6.0.174",
    "ink": "^7.0.1",
    "ink-spinner": "^5.0.0",
    "react": "^19.2.5",
    "shelljs": "^0.10.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/shelljs": "^0.10.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
